# MercadoLibre OAuth2 credentials
# Copy to ~/.hermes/.env (or merge with the existing file) and chmod 600.
# Create your app at https://developers.mercadolibre.com.ar/devcenter

# --- Required (set manually) ---
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=https://localhost:8080/callback

# Default site / country
#   MLA = Argentina       MLM = Mexico        MCO = Colombia
#   MLB = Brazil          MLC = Chile         MLU = Uruguay
ML_SITE=MLA

# --- Populated automatically by scripts/ml-oauth.sh ---
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=
ML_USER_ID=
ML_EXPIRES_AT=
